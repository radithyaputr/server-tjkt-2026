NODE_ENV=production
PORT=3000

# Database (MySQL / MariaDB)
DB_NAME=server_tjkt
DB_USER=tjkt_user
DB_PASSWORD=password_kuat_disini
DB_ROOT_PASSWORD=root_password_kuat_juga
DB_HOST=db
DB_PORT=3306

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# Upload limits (in MB)
MAX_FILE_SIZE_MB=200
MAX_MEMORY_SIZE_MB=50

# Admin seed password (used by seed.js)
ADMIN_PASSWORD=ganti_password_ini
